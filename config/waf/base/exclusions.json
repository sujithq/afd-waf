      "matchVariable": "QueryStringArgNames",
      "selectorMatchOperator": "Equals",
      "selector": "$select",
      "ruleSet": "Microsoft_DefaultRuleSet_2.1",
      "ruleGroup": "SQLI",
      "ruleId": "942100"
    },
    {
      "matchVariable": "QueryStringArgNames",
      "selectorMatchOperator": "Equals",
      "selector": "$expand",
      "ruleSet": "Microsoft_DefaultRuleSet_2.1",
      "ruleGroup": "SQLI",
      "ruleId": "942100"
    },
    {
      "matchVariable": "QueryStringArgNames",
      "selectorMatchOperator": "Equals",
      "selector": "$filter",
      "ruleSet": "Microsoft_DefaultRuleSet_2.1",
      "ruleGroup": "SQLI",
      "ruleId": "942100"
    },
    {
      "matchVariable": "QueryStringArgNames",
      "selectorMatchOperator": "Equals",
      "selector": "$orderby",
      "ruleSet": "Microsoft_DefaultRuleSet_2.1",
      "ruleGroup": "SQLI",
      "ruleId": "942110"
    },
    {
      "matchVariable": "QueryStringArgNames",
      "selectorMatchOperator": "Equals",
      "selector": "$top",
      "ruleSet": "Microsoft_DefaultRuleSet_2.1",
      "ruleGroup": "SQLI",
      "ruleId": "942100"
    },
    {
      "matchVariable": "QueryStringArgNames",
