{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WAF domain policy registry",
  "type": "object",
  "required": ["base", "domainPolicies"],
  "additionalProperties": false,
  "properties": {
    "base": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "domainPolicies": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "hostName", "apis"],
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "hostName": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9.-]+$"
          },
          "dnsZoneId": {
            "type": "string",
            "minLength": 1
          },
          "apis": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "pattern": "^[a-z0-9-]+$"
            },
            "additionalProperties": {
              "type": "object",
              "required": ["apimApiName"],
              "additionalProperties": false,
              "properties": {
                "apimApiName": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9._-]+$"
                }
              }
            }
          }
        }
      }
    }
  }
}
