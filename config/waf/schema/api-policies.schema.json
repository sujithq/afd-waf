{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WAF API policy registry",
  "type": "object",
  "required": ["base", "apiPolicies"],
  "additionalProperties": false,
  "properties": {
    "base": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "apiPolicies": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["apimApiName"],
        "additionalProperties": false,
        "properties": {
          "apimApiName": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._-]+$"
          }
        }
      }
    }
  }
}
